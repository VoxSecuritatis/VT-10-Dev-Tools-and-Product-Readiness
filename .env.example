# Copy this file to .env and fill in real values. Never commit .env itself.

# Required -- OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional -- Azure Application Insights connection string. If left blank, observability
# falls back to local JSONL logging only (no crash, no Azure calls).
AZURE_APPINSIGHTS_CONNECTION_STRING=
